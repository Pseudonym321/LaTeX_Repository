\begin {tikzpicture}[scale=2] \draw [-latex] (-0.5,0) -- (2,0); \draw [-latex] (0,-2) -- (0,2); \par \draw [] (0,1) arc [start angle=90, end angle=-90, radius=1]; \par \draw [] (0,0) -- (30:2); \draw [] (0,0) -- (-30:2); \par \draw [dashed] (0,0) -- (15:2); \draw [dashed] (0,0) -- (-15:2); \par \fill [] (30:5/8) circle [radius=0.035] node[above]{$p$}; \fill [] (30:7/8) circle [radius=0.035] node[above left]{$q$}; \fill [] (15:6/8) circle [radius=0.035] node[below right]{$z$}; \par \draw [green] (15:6/8) -- (30:5/8); \draw [green] (15:6/8) -- (30:7/8); \par \draw plot [smooth] coordinates {(0:0.8) (15:6/8) (30:5/8) (60:0.5)}; \draw plot [smooth] coordinates {(0:0.6) (15:6/8) (30:7/8) (40:1.5)}; \par \fill [] (-30:1.6) circle [radius=0.035] node[below]{$p^\prime $}; \fill [] (-30:1.143) circle [radius=0.035] node[below]{$q^\prime $}; \fill [] (-15:4/3) circle [radius=0.035] node[below right]{$z^\prime $}; \par \draw [green] (-15:8/6) -- (-30:8/5); \draw [green] (-15:8/6) -- (-30:8/7); \par \draw [black] (-15:6/8) -- (-30:5/8); \draw [black] (-15:6/8) -- (-30:7/8); \par \draw [dotted] (30:5/8) -- (-30:5/8); \draw [dotted] (30:7/8) -- (-30:7/8); \draw [dotted] (15:6/8) -- (-15:6/8); \par \draw plot [smooth] coordinates {(0:5/4) (-15:8/6) (-30:8/5) (-60:2)}; \draw plot [smooth] coordinates {(0:5/3) (-15:8/6) (-30:8/7) (-40:2/3)}; \par \coordinate (z) at (15:6/8); \coordinate (p) at (30:5/8); \coordinate (q) at (30:7/8); \par \draw pic["$\alpha $",draw,-,angle eccentricity=1.4, angle radius=0.3cm]{angle=q--z--p}; \par \coordinate (iz) at (-15:8/6); \coordinate (ip) at (-30:8/5); \coordinate (iq) at (-30:8/7); \par \draw pic["$\alpha $",draw,-,angle eccentricity=1.4, angle radius=0.3cm]{angle=iq--iz--ip}; \end {tikzpicture}
