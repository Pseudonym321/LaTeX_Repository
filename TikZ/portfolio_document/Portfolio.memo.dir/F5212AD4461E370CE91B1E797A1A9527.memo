\mmzSource 
\begin {tikzpicture}[tdplot_main_coords] \par \draw [-latex] (-4,0,0) -- (4,0,0) node[pos=1,below left]{$x$}; \draw [-latex] (0,-4,0) -- (0,4,0) node[pos=1,below right]{$y$}; \draw [] (-3.75,-3.75) -- (-3.75,3.75) -- (3.75,3.75) -- (3.75,-3.75) -- cycle; \foreach \x in {-3.75,-3.5,...,3.75}{ \draw [thin,dotted] (\x ,-3.75) -- (\x ,3.75);} \foreach \y in {-3.75,-3.5,...,3.75}{ \draw [thin,dotted] (-3.75,\y ) -- (3.75,\y );} \par \tdplotsetrotatedcoords {180+\az }{0}{0} \fill [tdplot_rotated_coords,white] ({cos(\azimuth )},{sin(\azimuth )}) arc [start angle=\azimuth , end angle={\azimuth +180}, radius=1] -- cycle; \fill [tdplot_screen_coords,white] ({cos(0)},{sin(0)}) arc [start angle=0, end angle=180, radius=1] -- cycle; \par \draw [tdplot_screen_coords,thin] (1,0) arc [start angle=0, end angle=180,radius=1]; \draw [tdplot_screen_coords,densely dashed,thin] (1,0) arc [start angle=0, end angle=-180,radius=1]; \path [tdplot_screen_coords,spath/save=pathname] (0,0) circle [radius=0.045]; \path [fill,spath/use={pathname, transform={shift={(0,0,1)}}}]; \tdplotsetrotatedcoords {0}{0}{0} \draw [tdplot_rotated_coords,densely dashed,thin] (\azimuth :1) arc [start angle=\azimuth , end angle={\azimuth +180}, radius=1]; \draw [tdplot_rotated_coords] (\azimuth :1) arc [start angle=\azimuth , end angle={\azimuth -180}, radius=1]; \par \par \foreach \x in {0.25,0.5,...,3.5}{ \tdplotsetrotatedcoords {0+\az }{{atan(1/\x )}}{0+\az } \path [tdplot_rotated_coords,spath/save=name] (0,0) circle [radius={sqrt(((2*\x )/(1+(\x )^2))^2+((-2)/(1+(\x )^2))^2)/2}]; \path [draw,red,spath/use={name, transform={shift={({cos(\az )*\x /(1+(\x )^2)},{sin(\az )*\x /(1+(\x )^2)},{((((\x )^2-1)/((\x )^2+1))+1)/2})}}}]; \tdplotsetrotatedcoords {90+\az }{{atan(1/\x )}}{0+\az } \path [tdplot_rotated_coords,spath/save=name] (0,0) circle [radius={sqrt(((2*\x )/(1+(\x )^2))^2+((-2)/(1+(\x )^2))^2)/2}]; \path [draw,blue,spath/use={name,transform={shift={({-sin(\az )*\x /(1+(\x )^2)},{cos(\az )*\x /(1+(\x )^2)},{((((\x )^2-1)/((\x )^2+1))+1)/2})}}}]; \tdplotsetrotatedcoords {180+\az }{{atan(1/\x )}}{0+\az } \path [tdplot_rotated_coords,spath/save=name] (0,0) circle [radius={sqrt(((2*\x )/(1+(\x )^2))^2+((-2)/(1+(\x )^2))^2)/2}]; \path [draw,green,spath/use={name,transform={shift={({-cos(\az )*\x /(1+(\x )^2)},{-sin(\az )*\x /(1+(\x )^2)},{((((\x )^2-1)/((\x )^2+1))+1)/2})}}}]; \tdplotsetrotatedcoords {270+\az }{{atan(1/\x )}}{0+\az } \path [tdplot_rotated_coords,spath/save=name] (0,0) circle [radius={sqrt(((2*\x )/(1+(\x )^2))^2+((-2)/(1+(\x )^2))^2)/2}]; \path [draw,yellow,spath/use={name,transform={shift={({sin(\az )*\x /(1+(\x )^2)},{-cos(\az )*\x /(1+(\x )^2)},{((((\x )^2-1)/((\x )^2+1))+1)/2})}}}]; } \par \par \path [draw,white,tdplot_screen_coords] (-5.5,-4.5) rectangle (5.5,4.5); \end {tikzpicture}
