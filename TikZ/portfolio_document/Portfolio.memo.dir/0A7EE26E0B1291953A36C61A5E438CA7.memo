\begin {tikzpicture}[tdplot_main_coords] \clip [tdplot_screen_coords] (-3,-3) rectangle (3,3); \def \Vt {10} \foreach \Vtheta in {30,40,...,250}{ \tdplotsetrotatedcoords {\Vtheta +90}{0}{0} \draw [tdplot_rotated_coords,domain=0:360,smooth,variable=\Vp ] plot (0,{sqrt((1/((cos(\Vt ))^2))-cos(\Vt ))*sin(\Vp )+(1/(cos(\Vt )))},{sqrt((1/((cos(\Vt ))^2))-cos(\Vt ))*cos(\Vp )}); } \foreach \Vtheta in {0,10,...,350}{ \draw [domain=20:240,smooth,variable=\Vp ] plot ({((1/(cos(\Vt )))+cos(\Vtheta )*sqrt((1/((cos(\Vt ))^2))-cos(\Vt )))*sin(\Vp )},{((1/(cos(\Vt )))+cos(\Vtheta )*sqrt((1/((cos(\Vt ))^2))-cos(\Vt )))*cos(\Vp )},{sqrt((1/((cos(\Vt ))^2))-cos(\Vt ))*sin(\Vtheta )}); } \draw [domain=30+180:250+180,samples=300,red,smooth,variable=\Vp ] plot ({((1/(cos(\Vt )))+(sqrt((1/((cos(\Vt ))^2))-cos(\Vt ))*cos(10*\Vp )))*cos(\Vp )}, {((1/(cos(\Vt )))+(sqrt((1/((cos(\Vt ))^2))-cos(\Vt ))*cos(10*\Vp )))*sin(\Vp )}, {sqrt((1/((cos(\Vt ))^2))-cos(\Vt ))*sin(10*\Vp )}); \par \par \par \par \def \Vt {40} \foreach \Vtheta in {30,40,...,250}{ \tdplotsetrotatedcoords {\Vtheta +90}{0}{0} \draw [tdplot_rotated_coords,domain=0:360,smooth,variable=\Vp ] plot (0,{sqrt((1/((cos(\Vt ))^2))-cos(\Vt ))*sin(\Vp )+(1/(cos(\Vt )))},{sqrt((1/((cos(\Vt ))^2))-cos(\Vt ))*cos(\Vp )}); } \foreach \Vtheta in {0,10,...,350}{ \draw [domain=20:240,smooth,variable=\Vp ] plot ({((1/(cos(\Vt )))+cos(\Vtheta )*sqrt((1/((cos(\Vt ))^2))-cos(\Vt )))*sin(\Vp )},{((1/(cos(\Vt )))+cos(\Vtheta )*sqrt((1/((cos(\Vt ))^2))-cos(\Vt )))*cos(\Vp )},{sqrt((1/((cos(\Vt ))^2))-cos(\Vt ))*sin(\Vtheta )}); } \draw [domain=30+180:250+180,samples=50,red,smooth,variable=\Vp ] plot ({((1/(cos(\Vt )))+(sqrt((1/((cos(\Vt ))^2))-cos(\Vt ))*cos(10*\Vp )))*cos(\Vp )}, {((1/(cos(\Vt )))+(sqrt((1/((cos(\Vt ))^2))-cos(\Vt ))*cos(10*\Vp )))*sin(\Vp )}, {sqrt((1/((cos(\Vt ))^2))-cos(\Vt ))*sin(10*\Vp )}); \par \par \def \Vt {70} \foreach \Vtheta in {30,40,...,250}{ \tdplotsetrotatedcoords {\Vtheta +90}{0}{0} \draw [tdplot_rotated_coords,domain=0:360,smooth,variable=\Vp ] plot (0,{sqrt((1/((cos(\Vt ))^2))-cos(\Vt ))*sin(\Vp )+(1/(cos(\Vt )))},{sqrt((1/((cos(\Vt ))^2))-cos(\Vt ))*cos(\Vp )}); } \foreach \Vtheta in {0,10,...,350}{ \draw [domain=20:240,smooth,variable=\Vp ] plot ({((1/(cos(\Vt )))+cos(\Vtheta )*sqrt((1/((cos(\Vt ))^2))-cos(\Vt )))*sin(\Vp )},{((1/(cos(\Vt )))+cos(\Vtheta )*sqrt((1/((cos(\Vt ))^2))-cos(\Vt )))*cos(\Vp )},{sqrt((1/((cos(\Vt ))^2))-cos(\Vt ))*sin(\Vtheta )}); } \draw [domain=30+180:250+180,samples=50,red,smooth,variable=\Vp ] plot ({((1/(cos(\Vt )))+(sqrt((1/((cos(\Vt ))^2))-cos(\Vt ))*cos(10*\Vp )))*cos(\Vp )}, {((1/(cos(\Vt )))+(sqrt((1/((cos(\Vt ))^2))-cos(\Vt ))*cos(10*\Vp )))*sin(\Vp )}, {sqrt((1/((cos(\Vt ))^2))-cos(\Vt ))*sin(10*\Vp )}); \par \end {tikzpicture}
