\begin {tikzpicture}[tdplot_main_coords,scale=3] \begin {scope} \draw [-latex,very thin] (0,0,-1.5) -- (0,0,1.5); \fill [tdplot_screen_coords,white] (0,0) circle(1); \draw [densely dashed,very thin] (0,0,-1.5) -- (0,0,1.5); \draw [very thin,-latex] (-2.5,0,0) -- (2.5,0,0) node[pos=1,below] {$\scriptstyle x,\xi ,\mbox {\scriptsize Re}(z)$}; \draw [-latex,very thin] (0,-1.5,0) -- (0,1.5,0) node[pos=1,below]{$\scriptstyle y,\eta ,\mbox {\scriptsize Im}(z)$}; \tdplotsetrotatedcoords {180}{0}{0} \fill [tdplot_rotated_coords,white] ({cos(\azimuth )},{sin(\azimuth )}) arc [start angle=\azimuth , end angle={\azimuth +180}, radius=1] -- cycle; \fill [tdplot_screen_coords,white] ({cos(0)},{sin(0)}) arc [start angle=0, end angle=180, radius=1] -- cycle; \draw [very thin,densely dashed] (-2.5,0,0) -- (2.5,0,0); \draw [very thin,densely dashed] (0,-1.5,0) -- (0,1.5,0); \draw [densely dashed,very thin] (0,0,-1.5) -- (0,0,1.5); \draw [very thin] (0,0,1) -- (0,0,1.5); \end {scope} \par \draw [tdplot_screen_coords,very thin] (0,0) circle(1); \tdplotsetrotatedcoords {0}{0}{0} \draw [tdplot_rotated_coords,densely dashed,very thin] (\azimuth :1) arc [start angle=\azimuth , end angle={\azimuth +180}, radius=1]; \draw [tdplot_rotated_coords,very thin] (\azimuth :1) arc [start angle=\azimuth , end angle={\azimuth -180}, radius=1]; \par \newcommand {\Vthe }{60} \newcommand {\Vphi }{60} \par \coordinate (O) at (0,0); \coordinate (P) at ({\Sphx {\Vthe }{\Vphi }},{\Sphy {\Vthe }{\Vphi }},{\Sphz {\Vthe }{\Vphi }}); \coordinate (Pn) at ({\Sphx {\Vthe }{\Vphi }},{\Sphy {\Vthe }{\Vphi }},{0}); \coordinate (N) at (0,0,1); \coordinate (S) at (0,0,-1); \coordinate (Q) at ({\Sphx {\Vthe +180}{180-\Vphi }},{\Sphy {\Vthe +180}{180-\Vphi }},{\Sphz {\Vthe +180}{180-\Vphi }}); \coordinate (z) at ({\SPx {\Vthe }{\Vphi }},{\SPy {\Vthe }{\Vphi }}); \coordinate (W) at ({\SPx {\Vthe +180}{180-\Vphi }},{\SPy {\Vthe +180}{180-\Vphi }}); \par \draw [very thin] (O) -- (P) -- (Pn); \draw [very thin] (N) -- (z) -- (O); \draw [very thin] (O) -- (Q); \draw [dashed,very thin] (N) -- (Q); \draw [very thin] (O) -- (W); \draw [-latex,very thin] (0.25,0) arc [start angle=0, end angle=\Vthe ,radius=0.25] node[pos=0.5,below]{$\scriptstyle \theta $}; \draw [-latex,very thin] (0.15,0) arc [start angle=0, end angle=\Vthe +180,radius=0.15] node[pos=0.95,above]{$\scriptstyle \theta _w$}; \tdplotsetrotatedcoords {\Vthe }{0}{0} \draw [tdplot_rotated_coords,very thin,-latex,smooth,variable=\Vt ,domain=90:90-\Vphi ] plot ({0.3*cos(\Vt )},{0},{0.3*sin(\Vt )}) node[pos=0,above right=5pt,scale=1/3]{$\scriptstyle \phi $}; \draw pic[draw,-,angle eccentricity=1.4, angle radius=0.2cm]{right angle=O--Pn--P}; \par \path [tdplot_screen_coords,spath/save=point] (0,0,0) circle(0.025); \fill [][spath/use={point, transform={shift={(W)}}}] node[above left]{$\scriptstyle W$}; \fill [][spath/use={point, transform={shift={(N)}}}] node[above left]{$\scriptstyle N$}; \fill [][spath/use={point, transform={shift={(P)}}}] node[above right]{$\scriptstyle P$}; \fill [][spath/use={point, transform={shift={(z)}}}] node[right]{$\scriptstyle z$}; \fill [][spath/use={point, transform={shift={(Q)}}}] node[above left]{$\scriptstyle Q$}; \fill [][spath/use={point, transform={shift={(O)}}}] node[below left=5pt]{$\scriptstyle O$}; \fill [][spath/use={point, transform={shift={(S)}}}] node[right]{$\scriptstyle S$}; \par \end {tikzpicture}
